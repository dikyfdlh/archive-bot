# Archive Manager Bot - example .env
# Copy ke .env dan isi nilai aslinya. Jangan commit .env asli ke git.

# === Server ===
PORT=3000
# Domain HTTPS publik tempat bot dipasang. Webhook Meta akan menunjuk ke <PUBLIC_BASE_URL>/webhook
PUBLIC_BASE_URL="https://arsip.domain-kamu.com"
# Maksimum body request webhook dalam byte (default 10 MB)
WEBHOOK_MAX_BODY_BYTES=10485760
# Token untuk membuka /admin dari internet. WAJIB diisi sebelum publish ke publik.
ADMIN_TOKEN=""

# === WhatsApp Cloud API ===
WHATSAPP_API_VERSION=v25.0
# Verify token bebas; samakan dengan yang dipasang di dashboard Meta saat subscribe webhook.
WHATSAPP_VERIFY_TOKEN="ganti-verify-token-yang-panjang-dan-acak"
# Access token permanen dari System User Meta Business (BUKAN token user 24 jam).
WHATSAPP_ACCESS_TOKEN=""
# Phone Number ID dari Meta -> WhatsApp -> API Setup. Numerik panjang (15+ digit).
# BUKAN nomor HP "62895...". Salah satu sumber error 404 paling umum.
WHATSAPP_PHONE_NUMBER_ID=""
# App Secret dari Meta Developers -> Settings -> Basic. Untuk validasi X-Hub-Signature-256.
# Sangat disarankan diisi untuk production.
WHATSAPP_APP_SECRET=""
# Nomor WhatsApp yang boleh pakai bot. Pisahkan dengan koma. Format tanpa +.
# Kosongkan untuk membuka ke siapa saja (TIDAK direkomendasikan).
AUTHORIZED_WA_NUMBERS=""

# === Google Drive ===
# service_account = rekomendasi untuk bot. oauth_access_token = quick test saja.
GOOGLE_DRIVE_AUTH_MODE=service_account
# ID folder Drive tujuan, ambil dari URL: drive.google.com/drive/folders/<ID>
GOOGLE_DRIVE_FOLDER_ID=""
GOOGLE_DRIVE_SCOPE=https://www.googleapis.com/auth/drive
# Email service account (format: nama@project.iam.gserviceaccount.com).
# BUKAN email Gmail pribadi. Share folder Drive ke email ini sebagai Editor.
GOOGLE_SERVICE_ACCOUNT_EMAIL=""
# Tempel isi field "private_key" dari JSON service account.
# Newline boleh ditulis literal sebagai \n; loader akan men-decode otomatis.
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nISI_PRIVATE_KEY\n-----END PRIVATE KEY-----\n"
# HANYA isi jika kamu pakai Google Workspace dengan domain-wide delegation aktif.
# Untuk akun Gmail (@gmail.com) atau service account biasa: KOSONGKAN.
# Kalau diisi sembarangan, JWT akan ditolak dengan unauthorized_client.
GOOGLE_DRIVE_IMPERSONATE_USER=""
# Hanya dipakai kalau GOOGLE_DRIVE_AUTH_MODE=oauth_access_token.
GOOGLE_OAUTH_ACCESS_TOKEN=""

# === Archive Bot ===
ARCHIVE_STORAGE_PATH=./data/archive-index.json
# true = kirim file langsung ke WA jika ukuran <= MAX_SEND_FILE_BYTES. false = kirim link saja.
SEND_FILES_DIRECTLY=true
# Batas ukuran file yang dikirim langsung. WA Cloud API batas atas ~100 MB.
MAX_SEND_FILE_BYTES=95000000
